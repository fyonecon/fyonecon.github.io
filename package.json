    "@tailwindcss/vite": "^4.1.17",
    "svelte": "5.53.5",
    "svelte-check": "^4.3.4",
    "svelte-copy": "^2.0.0",
    "tailwindcss": "^4.1.17",
    "typescript": "^5.9.3",
    "vite": "^7.2.2",
    "wrangler": "^4.63.0"
  },
  "dependencies": {
